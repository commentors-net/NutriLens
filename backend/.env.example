# Backend Environment Variables
# Copy this file to .env and fill in your configuration
# DO NOT commit the .env file to version control

# ── Environment ────────────────────────────────────────────────────────────────
# "development" → SQLite (local dev / tests)
# any other value (e.g. "production") → Firestore (Cloud Run)
ENVIRONMENT=development

# ── API Configuration ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000          # local dev; Cloud Run always binds 8080
API_DEBUG=True

# ── Database (local dev only — ignored in production) ─────────────────────────
DATABASE_URL=sqlite:///./nutrition_cloud.db

# ── Google Cloud / Firestore (required in production) ─────────────────────────
GCP_PROJECT_ID=leave-tracker-2025
# Path to service account JSON when running outside Cloud Run:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── CORS Origins (comma-separated) ────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── AI/ML Service ─────────────────────────────────────────────────────────────
# Optional: enable real NutriLens photo analysis with Gemini multimodal.
GEMINI_API_KEY=
NUTRILENS_ANALYSIS_MODEL=gemini-2.0-flash-lite

# ── Google OAuth (for SSO login) ───────────────────────────────────────────────
# Get this from Google Cloud Console > APIs & Credentials > OAuth 2.0 Client IDs
# Create a new OAuth 2.0 Client ID with type "Web application"
# Add authorized JavaScript origins: http://localhost:5173, http://localhost:5174
# Add authorized redirect URIs if needed
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here.apps.googleusercontent.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
