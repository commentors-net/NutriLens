# Local environment variables for development
# Copy this to .env.development and .env.production with appropriate values
VITE_API_URL=http://localhost:8000

# Registration Feature Toggle
# Set to 'true' to enable public registration
# Set to 'false' to disable registration (recommended for production)
VITE_ENABLE_REGISTRATION=false

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
# See GOOGLE_OAUTH_SETUP.md for full setup instructions
# Leave blank to disable Google Sign-In
VITE_GOOGLE_CLIENT_ID=
